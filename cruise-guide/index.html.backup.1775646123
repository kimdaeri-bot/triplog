      margin-top: 14px;
      background: #ff6f00; color: #fff;
      font-size: 0.83rem; font-weight: 700;
      padding: 8px 18px; border-radius: 8px;
      text-decoration: none; transition: background .2s;
    }
    .cat-card:hover .go-btn { background: #e65100; }
